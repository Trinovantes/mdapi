{
    "name": "@trinovantes/mdapi",
    "type": "module",
    "version": "0.2.12",
    "description": "MangaDex API wrapper",
    "license": "MIT",
    "private": false,
    "sideEffects": false,
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        }
    },
    "files": [
        "tsconfig.json",
        "dist/*",
        "src/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Trinovantes/mdapi"
    },
    "author": {
        "name": "Stephen",
        "email": "hello@stephenli.ca",
        "url": "https://www.stephenli.ca"
    },
    "scripts": {
        "clean": "rm -rf ./dist ./demo/dist",
        "build": "vite build",
        "prepublishOnly": "rm -rf ./dist && pnpm build",
        "lint": "tsc && eslint",
        "test": "vitest",
        "cloc": "cloc --vcs=git"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^24.12.0",
        "eslint": "^10.1.0",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "vite": "^8.0.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.1",
        "vue": "^3.5.30",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.6"
    }
}
